  "latitude_bands": {
    "description": "Hashsite uses three latitude bands per hemisphere with boundaries at 0\u00b0, \u00b119.47\u00b0 (= arcsin(1/3)), and \u00b141.81\u00b0. The second character of a 2-char hashsite encodes longitude within the band. Because each band has a different number of longitude columns (to keep cell areas more equal), the second character changes discontinuously across a band boundary even at the same longitude. This is intentional.",
    "all_vectors_use_lon": 0.001,
    "note": "Vectors at lon\u22480 (prime meridian). The second char at lon=0 is NOT '0' because '0' (value 0) maps to the westernmost cell of each band, and the prime meridian is not at the western edge of the encoding origin. The encoding origin is lon=-180\u00b0 (antimeridian), not lon=0\u00b0.",
    "bands": [
      {
        "boundary_lat": 0.0,
        "description": "Equator",
        "lon_used": 0.001,
        "just_south": {
          "lat": -0.001,
          "code_2char": "#L0"
        },
        "just_north": {
          "lat": 0.001,
          "code_2char": "#FR"
        },
        "note": "First char changes (L\u2192F) \u2014 different latitude band. Second char also changes (0\u2192R) because each band has a different number of longitude subdivisions."
      },
      {
        "boundary_lat": 19.47,
        "description": "19.47\u00b0 = arcsin(1/3)",
        "lon_used": 0.001,
        "just_south": {
          "lat": 19.469,
          "code_2char": "#F0"
        },
        "just_north": {
          "lat": 19.471,
          "code_2char": "#9R"
        },
        "note": "First char changes (F\u21929) \u2014 different latitude band. Second char also changes (0\u2192R) because each band has a different number of longitude subdivisions."
      },
      {
        "boundary_lat": 41.81,
        "description": "41.81\u00b0 \u2014 polar zone begins",
        "lon_used": 0.001,
        "just_south": {
          "lat": 41.809,
          "code_2char": "#90"
        },
