  "altitude_spec_cases": [
    {
      "meters": 1,
      "encoded": "^1",
      "mode": "coarse",
      "note": "Value 1 = +1m. Range: J=-1 through H=+17 in single char."
    },
    {
      "meters": 0.01,
      "encoded": "^I00CYK5R",
      "mode": "precision",
      "note": "I prefix = precision mode. Subsequent chars fractional (\u00f736 each)."
    },
    {
      "meters": 100001,
      "encoded": "^255T",
      "mode": "coarse",
      "note": "4-char big-endian: 2\u00d736\u00b3 + 5\u00d736\u00b2 + 5\u00d736 + 29 = 100001"
    },
    {
      "meters": -10,
      "encoded": "^S",
      "mode": "coarse",
      "note": "S = value 28 = 18+10. Sign in first char: J=-1, S=-10, Z=-17"
    }
  ],
